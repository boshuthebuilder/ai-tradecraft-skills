#!/bin/bash
# agy-review — run an adversarial cross-model review of a GitHub PR via the Antigravity
# CLI (agy), deterministically and fail-loud. The Gemini leg of the adversarial-review
# skill's fallback chain (Codex → Gemini → independent agent). Repo-agnostic: run it from
# inside a checkout of the repo under review.
#
#   agy-review <pr-number> [--repo owner/name] [--label <text>] [--model <label>]
#
# --model runs the review on another model in the Antigravity pool (see `agy models` for
# labels — Gemini, Claude and GPT families) — a SEPARATE subscription quota from the
# primary Claude/ChatGPT plans, so reviews can run without spending primary headroom.
# agy itself fails loud (rc=1, valid labels listed) on an unknown label. Every result
# line carries the run's conversation id: interrogate any run afterwards with
#   agy --conversation <id> -p "your follow-up"     (--conversation BEFORE -p)
#
# --repo defaults to the checkout's GitHub remote (gh repo view). The reviewer reads files
# from an ISOLATED detached worktree at the PR head (not the caller's live tree — see class 5),
# so run from the repo being reviewed but keep editing your own checkout meanwhile.
#
# Why this wrapper exists — every failure class below was hit in production and each
# failed SILENTLY (agy printed nothing, posted nothing, exit 0), which reads as a hang
# (classes 1-4); class 5 instead corrupted the CALLER's checkout:
#   1. permission-denied  headless -p mode auto-denies EVERY confirmable tool unless
#                         ~/.gemini/config/config.json carries
#                         userSettings.globalPermissionGrants.allow. Two distinct layers:
#                         "command(git)"-style PREFIX rules for Bash ('git' matches
#                         'git add', NOT 'github'), and "read_file(*)" for agy's INTERNAL
#                         read tools (Search/GrepSearch/file viewing) — without the
#                         latter it dies the moment it greps. The two look-alike files
#                         (~/.gemini/settings.json — that's gemini-cli's — and
#                         ~/.gemini/antigravity-cli/settings.json) are NOT consulted.
#                         See the skill's Machine setup section for the exact block.
#   2. print-timeout      -p mode's default wait is 5m; a real review runs longer and is
#                         killed mid-flight with no message. We pass --print-timeout.
#   3. stale-scratch      agy reviews in its own clone (~/.gemini/antigravity-cli/scratch/
#                         <repo>), which nobody fetches — a just-merged SHA doesn't exist
#                         there and every git show fails. We fetch it first.
#   4. auth-needed        an expired Antigravity login errors only in the debug log.
#   5. contested-tree     agy's workspace layer checks out a pr-<n> branch in ITS cwd
#                         mid-review. When that cwd is the caller's live checkout it both
#                         strands the branch (bitten three times) and RACES a coordinator
#                         editing the same tree — a concurrent Edit hit a missing file
#                         because a background round had switched the branch back. We run
#                         agy in a detached worktree at the PR head (fetched into a per-run
#                         ref, checked out inside a private 0700 parent dir), so its
#                         branch-switching is isolated to a throwaway tree and the caller's
#                         checkout is never touched. Falls back (loud) to the caller's tree
#                         + a branch-restore guard if the worktree can't be made.
# The exit contract is typed-outcome: the ARTIFACT (a PR comment) is the success signal,
# never the exit code of agy itself.
#
#   exit 0  ok                 review comment posted on the PR
#   exit 2  auth-needed        not signed into Antigravity (run `agy` once interactively)
#   exit 3  permission-denied  headless grants missing/stripped (fix config.json, above)
#   exit 4  timeout            killed by the watchdog with no comment posted
#   exit 5  no-comment         agy exited but never posted (narration tail printed)
#   exit 6  bad-args / missing prerequisites
set -u

PR=""
REPO=""
LABEL=""
MODEL=""
while [ $# -gt 0 ]; do
  case "$1" in
    --repo)  [ $# -ge 2 ] || { echo "agy-review: --repo needs a value" >&2; exit 6; };  REPO="$2"; shift 2 ;;
    --label) [ $# -ge 2 ] || { echo "agy-review: --label needs a value" >&2; exit 6; }; LABEL="$2"; shift 2 ;;
    --model) [ $# -ge 2 ] || { echo "agy-review: --model needs a value (see \`agy models\` for labels)" >&2; exit 6; }; MODEL="$2"; shift 2 ;;
    -*) echo "agy-review: unknown flag $1" >&2; exit 6 ;;
    *) PR="$1"; shift ;;
  esac
done
# PR must be a bare integer — it is embedded in the prompt and a temp-file path
[[ "$PR" =~ ^[0-9]+$ ]] || { echo "usage: agy-review <pr-number> [--repo owner/name] [--label text] [--model label]" >&2; exit 6; }
for bin in agy gh git python3; do
  command -v "$bin" >/dev/null || { echo "agy-review: $bin not on PATH" >&2; exit 6; }
done

# The reviewed repo's checkout = the caller's cwd (NOT this script's location — it lives
# in the skills clone). The reviewer reads files from here via git -C.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || { echo "agy-review: run from inside a git checkout of the repo under review" >&2; exit 6; }
DERIVED="$(cd "$REPO_ROOT" && gh repo view --json nameWithOwner --jq .nameWithOwner 2>/dev/null)"
if [ -z "$REPO" ]; then
  REPO="$DERIVED"
  [ -n "$REPO" ] || { echo "agy-review: cannot derive the GitHub repo from this checkout — pass --repo owner/name" >&2; exit 6; }
elif [ -n "$DERIVED" ] && [ "$REPO" != "$DERIVED" ]; then
  # legitimate for fork workflows (checkout=fork, --repo=upstream) but loud: the reviewer reads
  # FILES from this checkout — if it doesn't carry the PR's code, git show/cat will read the wrong tree
  echo "agy-review: WARN repo-mismatch — reviewing $REPO but the checkout here is $DERIVED; file reads come from this checkout" >&2
fi
REPO_NAME="${REPO##*/}"
MARKER="Adversarial review by Gemini (agy)"
WATCHDOG_SECS=1000          # > --print-timeout so agy's own limit fires first
PRINT_TIMEOUT="15m"

# ---- pre-flight ----------------------------------------------------------------------
# grants: the config regression that silently kills every headless run. Checked
# statically (free) — the run itself confirms dynamically (jetski's own denial message).
# CONFIG rides an env var into a single-quoted script, so a hostile $HOME can't inject.
CONFIG="$HOME/.gemini/config/config.json"
if ! CONFIG="$CONFIG" python3 -c '
import json, os, sys
d = json.load(open(os.environ["CONFIG"]))
rules = d.get("userSettings", {}).get("globalPermissionGrants", {}).get("allow", [])
ok = any(r.startswith("command(git") for r in rules) and "read_file(*)" in rules
sys.exit(0 if ok else 1)
' 2>/dev/null; then
  echo "agy-review: permission-denied — $CONFIG lacks userSettings.globalPermissionGrants.allow" >&2
  echo "  (needs \"command(git)\"-style Bash rules AND \"read_file(*)\" for agy's internal Search/read tools;" >&2
  echo "   headless agy silently auto-denies every confirmable tool without them — see the" >&2
  echo "   adversarial-review skill's Machine setup section for the exact block)" >&2
  exit 3
fi

# scratch: the clone agy actually reviews in. It must EXIST and be FRESH before the run:
# absent, agy bootstraps one itself via commands outside the allow-list and dies silently
# at step 1 (hit live on the first review of a repo agy had never seen); stale, every
# git show of a freshly-merged SHA fails. We clone/fetch it from OUR shell, deterministically.
SCRATCH="$HOME/.gemini/antigravity-cli/scratch/$REPO_NAME"
if [ -d "$SCRATCH/.git" ]; then
  # --tags fetches tags IN ADDITION to the default branch refspec (git-fetch(1)), not instead of it
  git -C "$SCRATCH" fetch --tags origin >/dev/null 2>&1 \
    || echo "agy-review: WARN stale-scratch — fetch of $SCRATCH failed; a recent SHA may be invisible to agy" >&2
else
  mkdir -p "$(dirname "$SCRATCH")"   # a clean machine has no scratch dir at all yet
  git clone --quiet "https://github.com/$REPO.git" "$SCRATCH" >/dev/null 2>&1 \
    || echo "agy-review: WARN no-scratch — clone into $SCRATCH failed; agy may die bootstrapping its own" >&2
fi

# Artifact baseline: verification is COUNT-based (more marker comments after than before),
# immune to clock skew between this host and GitHub and to a failing `date`.
count_marker_comments() {
  gh pr view "$PR" --repo "$REPO" --json comments \
    --jq "[.comments[] | select((.body // \"\") | startswith(\"$MARKER\"))] | length" 2>/dev/null
}
BEFORE="$(count_marker_comments)"
[[ "$BEFORE" =~ ^[0-9]+$ ]] || { echo "agy-review: cannot read $REPO#$PR comments (gh auth? network?)" >&2; exit 6; }

# temp file created only after pre-flight, so an early exit leaks nothing
# (macOS mktemp requires the XXXXXX at the END of the template — no suffix after it)
OUT="$(mktemp "/tmp/agy-review-${PR}.XXXXXX")"

# ---- isolate the review in a throwaway worktree --------------------------------------
# agy's workspace layer checks out a pr-<n> branch in ITS cwd mid-review; when that cwd is the
# caller's live checkout it both strands the branch AND races a coordinator editing the same tree
# (field telemetry from a consumer project: a concurrent Edit hit a missing file because a background
# round had switched the branch back). So the reviewer runs in a DETACHED worktree at the PR head:
# agy's branch-switching is isolated to a throwaway tree, the caller's checkout is never touched, and
# file reads see the exact PR version regardless of the caller's current branch. Falls back to the
# caller's checkout (loud) if the worktree can't be made — in which case do not edit it mid-review.
WORKTREE=""; WT_PARENT=""; FETCH_REF="refs/agy-review/pr-$PR-$$"
cleanup_worktree() {
  [ -n "$WORKTREE" ]  && git -C "$REPO_ROOT" worktree remove --force "$WORKTREE" >/dev/null 2>&1
  [ -n "$WT_PARENT" ] && rmdir "$WT_PARENT" >/dev/null 2>&1
  git -C "$REPO_ROOT" update-ref -d "$FETCH_REF" >/dev/null 2>&1   # the per-run fetch ref
  WORKTREE=""; WT_PARENT=""
}
trap cleanup_worktree EXIT
REVIEW_ROOT="$REPO_ROOT"
# Fetch the PR head from the PR's own repo URL (robust to a fork checkout whose origin isn't $REPO)
# into a PER-RUN ref, never the shared FETCH_HEAD: a concurrent agy-review on the same checkout could
# overwrite FETCH_HEAD between our fetch and our rev-parse and we would build the worktree from the
# WRONG PR. $$ makes the ref unique per run; '+' force-updates a stale ref from a crashed prior run.
if git -C "$REPO_ROOT" fetch -q "https://github.com/$REPO.git" "+pull/$PR/head:$FETCH_REF" 2>/dev/null \
   && PR_HEAD="$(git -C "$REPO_ROOT" rev-parse "$FETCH_REF" 2>/dev/null)" && [ -n "$PR_HEAD" ]; then
  # mktemp -d gives a PRIVATE (mode 0700) parent dir atomically; point the worktree at a not-yet-
  # existing CHILD of it. Two wins: `git worktree add` always accepts a non-existent path (older git
  # rejects an existing dir, even empty), and the 0700 parent blocks other local users on a shared
  # host from traversing in to the checked-out PR source (git worktree add itself honours only umask,
  # typically 0755). No mktemp -u (races) and no rmdir dance (recreates the dir world-readable).
  WT_PARENT="$(mktemp -d "/tmp/agy-review-wt-${PR}.XXXXXX")"
  _wt="$WT_PARENT/pr"
  if [ -n "$WT_PARENT" ] && git -C "$REPO_ROOT" worktree add --detach "$_wt" "$PR_HEAD" >/dev/null 2>&1; then
    WORKTREE="$_wt"; REVIEW_ROOT="$_wt"
  else
    echo "agy-review: WARN no-worktree — could not add a worktree; reviewing in the caller's checkout ($REPO_ROOT). Do NOT edit it while the review runs." >&2
  fi
else
  echo "agy-review: WARN no-worktree — could not fetch pull/$PR/head; reviewing in the caller's checkout ($REPO_ROOT). Do NOT edit it while the review runs." >&2
fi
# Only when the worktree exists is REVIEW_ROOT guaranteed at the PR head; in the fallback it is the
# caller's checkout on whatever branch they are on, so we must NOT tell the reviewer its files are
# the PR version (it would review the wrong revision — gh pr diff in step 1 stays authoritative).
PR_HEAD_NOTE=""
[ -n "$WORKTREE" ] && PR_HEAD_NOTE=" The checkout at $REVIEW_ROOT is already at this PR's head, so its working files ARE the PR version."

# ---- the review ----------------------------------------------------------------------
# The prompt pins tool usage to prefix-matchable commands: git -C / gh --repo, no cd,
# no && chains — a chained command's first word is what the allow-rules match against —
# and names the exact allowed set: ANY un-granted command the model invents is fatal.
PROMPT="You are an adversarial code reviewer. Review PR #$PR in $REPO.${LABEL:+ Focus: $LABEL.}

Rules for tools — IMPORTANT, any command outside this list is hard-denied and kills the whole session:
you may ONLY run git (as 'git -C $REVIEW_ROOT ...'), gh pr view/diff/comment (with '--repo $REPO'),
ls, cat, head, tail, grep, rg, find, 'sed -n', wc, 'uv run', and 'bash -n'. Never cd; never
chain commands with && or ; (the permission gate matches the FIRST word only).

Steps:
1. Run: gh pr view $PR --repo $REPO   and   gh pr diff $PR --repo $REPO
2. Review the diff ADVERSARIALLY for correctness and security — real defects, not style. Read any file the diff touches (git -C $REVIEW_ROOT show, cat, grep) as needed to verify claims against the surrounding code.$PR_HEAD_NOTE
3. Post your findings as a PR comment with ONE direct call: gh pr comment $PR --repo $REPO --body \"...\" — pass the whole body INLINE via --body. Do NOT stage the body in a file first: echo, printf, shell redirection and file-write tools are all denied and will kill the session at this final step. CRITICAL: use NO backticks anywhere in the body — the permission validator parses backticks as command substitutions and permission-checks their contents, so a body quoting any identifier in backticks dies here; write code identifiers in 'single quotes' instead. The comment MUST start with '$MARKER:' and give a clear verdict (APPROVE / CHANGES-REQUESTED) plus findings as file:line, severity, and why each is a real defect. If nothing substantive, say so explicitly. Then stop."

# kill the whole descendant tree, depth-first — agy spawns node/language-server children
# that spawn their own; a one-level pkill -P orphans the grandchildren.
kill_tree() {
  local pid="$1" child
  for child in $(pgrep -P "$pid" 2>/dev/null); do kill_tree "$child"; done
  kill -KILL "$pid" 2>/dev/null
}

# Second line of defence for the FALLBACK path only: when the worktree could not be made and
# agy runs in the caller's checkout, its workspace layer can check out a pr-<n> branch here
# mid-review and strand the branch (bitten three times). In the worktree path REVIEW_ROOT is a
# throwaway tree, so agy's branch-switching lands there and REPO_ROOT is never touched. Record
# and restore REPO_ROOT's branch around the run regardless — a no-op unless the fallback fired.
BRANCH_BEFORE="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null)"

# Launch agy with its cwd set to REVIEW_ROOT so ALL of its own git operations (workspace checkout,
# branch switches) act on the throwaway worktree, not the caller's tree. exec makes the backgrounded
# subshell BECOME agy, so AGY_PID is agy itself and kill_tree reaps its real descendant tree.
( cd "$REVIEW_ROOT" && exec agy ${MODEL:+--model "$MODEL"} --print-timeout "$PRINT_TIMEOUT" --log-file "$OUT.log" -p "$PROMPT" ) >"$OUT" 2>&1 &
AGY_PID=$!
# the subshell inherits kill_tree, so the timeout path reaps the FULL descendant tree
( sleep "$WATCHDOG_SECS" & wait $!
  kill_tree "$AGY_PID" ) &
WATCHDOG_PID=$!
disown "$WATCHDOG_PID" 2>/dev/null   # keep its kill out of the shell's job-status noise
wait "$AGY_PID"
RC=$?
kill_tree "$WATCHDOG_PID"            # also reaps the watchdog's sleeping child

# restore the caller's branch if the review stranded it (only when clean — never discard work)
BRANCH_AFTER="$(git -C "$REPO_ROOT" branch --show-current 2>/dev/null)"
if [ -n "$BRANCH_BEFORE" ] && [ "$BRANCH_AFTER" != "$BRANCH_BEFORE" ]; then
  if [ -z "$(git -C "$REPO_ROOT" status --porcelain 2>/dev/null)" ]; then
    git -C "$REPO_ROOT" checkout "$BRANCH_BEFORE" >/dev/null 2>&1       && echo "agy-review: restored stranded branch ($BRANCH_AFTER -> $BRANCH_BEFORE)" >&2
  else
    echo "agy-review: WARN branch-stranded — review left the checkout on $BRANCH_AFTER (was $BRANCH_BEFORE); dirty tree, not auto-restoring" >&2
  fi
fi

# ---- verify by artifact --------------------------------------------------------------
AFTER="$(count_marker_comments)"
# the conversation id makes any run interrogable after the fact:
#   agy --conversation <id> -p "your follow-up"   (--conversation BEFORE -p)
CONV="$(grep -oE "Created conversation [0-9a-f-]{36}" "$OUT.log" 2>/dev/null | head -1 | awk '{print $3}')"
if [[ "$AFTER" =~ ^[0-9]+$ ]] && [ "$AFTER" -gt "$BEFORE" ]; then
  echo "agy-review: ok — review comment posted on $REPO#$PR${CONV:+ · conversation: $CONV}"
  rm -f "$OUT" "$OUT.log"
  exit 0
fi

# classify the failure — loud, never a bare nonzero. Order matters: the watchdog kill is
# checked FIRST (a killed run's captured output may echo reviewed content containing the
# denial phrase); the denial/auth greps then match only jetski's own final stderr line,
# not review content quoted in the narration.
echo "agy-review: FAILED — no new review comment on $REPO#$PR (debug log kept at $OUT.log${CONV:+; interrogate it: agy --conversation $CONV -p \"...\"}). Narration tail:" >&2
tail -6 "$OUT" >&2
if [ "$RC" -ge 128 ]; then
  echo "agy-review: timeout — killed by watchdog after ${WATCHDOG_SECS}s" >&2; exit 4
elif grep -Eq "^jetski: .*auto-denied" "$OUT"; then
  echo "agy-review: permission-denied — headless grants rejected mid-run (check $CONFIG)" >&2; exit 3
elif grep -Eiq "^(jetski|error): .*(not logged in|not signed in|authentication required)" "$OUT"; then
  echo "agy-review: auth-needed — run 'agy' once interactively to sign in" >&2; exit 2
else
  echo "agy-review: no-comment — agy exited rc=$RC without posting; advance the fallback chain (independent agent)" >&2; exit 5
fi
